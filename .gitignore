# ═══════════════════════════════════════════════════════════════
#  Environment secrets (use .env.example as template)
# ═══════════════════════════════════════════════════════════════
.env

# ═══════════════════════════════════════════════════════════════
#  Python
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ═══════════════════════════════════════════════════════════════
#  Virtual environments
# ═══════════════════════════════════════════════════════════════
.venv/
venv/
env/
.env
# ═══════════════════════════════════════════════════════════════
#  Testing / Coverage
# ═══════════════════════════════════════════════════════════════
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ═══════════════════════════════════════════════════════════════
#  MLflow artifacts & tracking database
# ═══════════════════════════════════════════════════════════════
mlruns/
mlflow.db


# ═══════════════════════════════════════════════════════════════
#  Generated plots (regenerated by pipeline)
# ═══════════════════════════════════════════════════════════════
plots/
*.png
*.log

# ═══════════════════════════════════════════════════════════════
#  IDE / Editor
# ═══════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════════
#  Data files (large / downloaded at runtime)
# ═══════════════════════════════════════════════════════════════
*.csv
!tests/**/*.csv
!Dashboard/*.csv
